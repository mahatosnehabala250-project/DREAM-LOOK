generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
  // For Vercel/Turso: set TURSO_DATABASE_URL + TURSO_AUTH_TOKEN as env vars
  // Local dev uses DATABASE_URL = file:./db/custom.db
}

model Advance {
  id              String   @id @default(cuid())
  employeeId      String
  branchId        String
  amount          Float
  reason          String
  date            String
  recoveredAmount Float    @default(0)
  remainingAmount Float
  givenBy         String?
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  Store           Store    @relation(fields: [branchId], references: [id])
  Employee        Employee @relation(fields: [employeeId], references: [id])
}

model Appointment {
  id          String       @id @default(cuid())
  customerId  String
  storeId     String
  employeeId  String
  serviceId   String
  date        String
  time        String
  status      String       @default("PENDING")
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt DateTime @updatedAt
  Service     Service      @relation(fields: [serviceId], references: [id])
  Employee    Employee     @relation(fields: [employeeId], references: [id])
  Store       Store        @relation(fields: [storeId], references: [id])
  Customer    Customer     @relation(fields: [customerId], references: [id])
  Transaction Transaction?
}

model Attendance {
  id         String   @id @default(cuid())
  employeeId String
  storeId    String
  date       String
  checkIn    String?
  checkOut   String?
  status     String   @default("PRESENT")
  createdAt  DateTime @default(now())
  updatedAt DateTime @updatedAt
  markedBy   String?
  Store      Store    @relation(fields: [storeId], references: [id])
  Employee   Employee @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  performedBy String
  targetData  String?
  oldValue    String?
  newValue    String?
  branchId    String?
  timestamp   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt DateTime @updatedAt
  Employee    Employee @relation(fields: [performedBy], references: [id])
}

model Customer {
  id          String        @id @default(cuid())
  name        String
  phone       String
  email       String?
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt DateTime @updatedAt
  Appointment Appointment[]
}

model DayClose {
  id            String   @id @default(cuid())
  branchId      String
  date          String
  totalRevenue  Float
  totalCash     Float
  totalOnline   Float
  totalServices Int
  closedBy      String?
  closedAt      DateTime @default(now())
  isLocked      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt DateTime @updatedAt
  Store         Store    @relation(fields: [branchId], references: [id])

  @@unique([branchId, date])
}

model Employee {
  id          String        @id @default(cuid())
  name        String
  phone       String        @unique
  role        String        @default("STYLIST")
  avatar      String?
  storeId     String
  isActive    Boolean       @default(true)
  joiningDate String        @default("2026-01-01")
  skillTags   String        @default("")
  createdAt   DateTime      @default(now())
  updatedAt DateTime @updatedAt
  Advance     Advance[]
  Appointment Appointment[]
  Attendance  Attendance[]
  AuditLog    AuditLog[]
  Store       Store         @relation(fields: [storeId], references: [id])
  Leave       Leave[]
  Payment     Payment[]
  Transaction Transaction[]
}

model Expense {
  id          String   @id @default(cuid())
  storeId     String
  category    String
  description String
  amount      Float
  expenseDate String
  createdAt   DateTime @default(now())
  updatedAt DateTime @updatedAt
  Store       Store    @relation(fields: [storeId], references: [id])
}

model Inventory {
  id           String   @id @default(cuid())
  storeId      String
  productId    String
  quantity     Float
  reorderLevel Float    @default(10)
  createdAt    DateTime @default(now())
  updatedAt DateTime @updatedAt
  Product      Product  @relation(fields: [productId], references: [id])
  Store        Store    @relation(fields: [storeId], references: [id])

  @@unique([storeId, productId])
}

model Leave {
  id         String    @id @default(cuid())
  employeeId String
  branchId   String
  date       String
  reason     String
  status     String    @default("PENDING")
  reviewedBy String?
  reviewedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt DateTime @updatedAt
  Store      Store     @relation(fields: [branchId], references: [id])
  Employee   Employee  @relation(fields: [employeeId], references: [id])

  @@unique([employeeId, date])
}

model Payment {
  id              String   @id @default(cuid())
  employeeId      String
  branchId        String
  date            String
  amount          Float
  earnedAmount    Float    @default(0)
  advanceDeducted Float    @default(0)
  netPaid         Float
  paymentMethod   String   @default("CASH")
  purpose         String   @default("DAILY_EARNINGS")
  notes           String?
  receiptNumber   String?
  paidBy          String?
  paidAt          DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  Store           Store    @relation(fields: [branchId], references: [id])
  Employee        Employee @relation(fields: [employeeId], references: [id])
}

model Product {
  id                 String               @id @default(cuid())
  name               String
  cost               Float
  unit               String               @default("ML")
  category           String
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt DateTime @updatedAt
  Inventory          Inventory[]
  TransactionProduct TransactionProduct[]
}

model Service {
  id              String        @id @default(cuid())
  name            String
  price           Float
  duration        Int
  category        String
  description     String?
  ownerPercent    Int           @default(50)
  employeePercent Int           @default(50)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime @updatedAt
  Appointment     Appointment[]
  Transaction     Transaction[]
}

model Store {
  id          String        @id @default(cuid())
  name        String
  address     String
  phone       String
  city        String
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt DateTime @updatedAt
  Advance     Advance[]
  Appointment Appointment[]
  Attendance  Attendance[]
  DayClose    DayClose[]
  Employee    Employee[]
  Expense     Expense[]
  Inventory   Inventory[]
  Leave       Leave[]
  Payment     Payment[]
  Transaction Transaction[]
}

model Transaction {
  id                 String               @id @default(cuid())
  appointmentId      String               @unique
  employeeId         String
  storeId            String
  serviceId          String
  servicePrice       Float
  ownerShare         Float
  employeeGrossShare Float
  totalProductCost   Float                @default(0)
  employeeNetShare   Float
  paymentMethod      String               @default("CASH")
  cashAmount         Float                @default(0)
  onlineAmount       Float                @default(0)
  isClosed           Boolean              @default(false)
  completedAt        DateTime             @default(now())
  createdAt          DateTime             @default(now())
  updatedAt DateTime @updatedAt
  Service            Service              @relation(fields: [serviceId], references: [id])
  Store              Store                @relation(fields: [storeId], references: [id])
  Employee           Employee             @relation(fields: [employeeId], references: [id])
  Appointment        Appointment          @relation(fields: [appointmentId], references: [id])
  TransactionProduct TransactionProduct[]
}

model TransactionProduct {
  id            String      @id @default(cuid())
  transactionId String
  productId     String
  quantityUsed  Float
  unitCost      Float
  totalCost     Float
  createdAt     DateTime    @default(now())
  updatedAt DateTime @updatedAt
  Product       Product     @relation(fields: [productId], references: [id])
  Transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
}
